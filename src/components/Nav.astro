---
const basePath = import.meta.env.BASE_URL;
const links = [
  { href: `${basePath}`, label: 'Home' },
  { href: `${basePath}docs/benvenuto`, label: 'Benvenuto' },
  { href: `${basePath}docs/guida-rapida`, label: 'Guida Rapida' },
  { href: `${basePath}docs/architettura`, label: 'Architettura' },
];
---

<nav class="border-b border-gray-200 mb-8 pb-4">
  <div class="flex items-center gap-6 flex-wrap">
    <a href={basePath} class="text-xl font-bold text-gray-900">PlayBook</a>
    <ul class="flex gap-4 list-none m-0 p-0">
      {links.map(({ href, label }) => (
        <li>
          <a href={href} class="text-gray-600 hover:text-gray-900 transition-colors">
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
