---
import BaseLayout from '../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL;
const pages = [
  { href: `${basePath}docs/benvenuto`, title: 'Benvenuto', desc: 'Introduzione al PlayBook' },
  { href: `${basePath}docs/guida-rapida`, title: 'Guida Rapida', desc: 'Come iniziare' },
  { href: `${basePath}docs/architettura`, title: 'Architettura', desc: 'Panoramica del progetto' },
  { href: `${basePath}category/empowerment`, title: 'Empowerment', desc: 'Esempio di pagina categoria — stile Organizing Playbook' },
];
---

<BaseLayout title="PlayBook">
  <h1 class="text-4xl font-bold mb-4">PlayBook</h1>
  <p class="text-lg text-gray-600 mb-8">Documentazione del progetto.</p>

  <div class="grid gap-4">
    {pages.map(({ href, title, desc }) => (
      <a href={href} class="block p-4 border border-gray-200 rounded-lg hover:border-gray-400 transition-colors">
        <h2 class="text-xl font-semibold">{title}</h2>
        <p class="text-gray-500 mt-1">{desc}</p>
      </a>
    ))}
  </div>
</BaseLayout>
